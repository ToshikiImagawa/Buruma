{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "$HOME/**" }]
    },
    "store:default"
  ]
}
