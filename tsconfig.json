{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@domain": ["./src/domain"],
      "@domain/*": ["./src/domain/*"],
      "@lib": ["./src/lib"],
      "@lib/*": ["./src/lib/*"],
      "@main/*": ["./src/processes/main/*"],
      "@renderer/*": ["./src/processes/renderer/*"],
      "@preload/*": ["./src/processes/preload/*"]
    },
    "outDir": "dist",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "jsx": "react-jsx"
  },
  "exclude": ["node_modules", "out", "dist", "**/__tests__/**"]
}
